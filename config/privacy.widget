#Api2

module("pipewire")

Private {

  Var audio_icon = "audio-input-microphone";
  Var video_icon = "camera-web";

  export grid {
    button{
      style = if(PipewireCount("AudioIn"), "module", "hidden")
      trigger = "pipewire"
      value = audio_icon;
      css = "* { color: red; }"
    }
    button{
      style = if(PipewireCount("VideoIn"), "module", "hidden")
      trigger = "pipewire"
      value = video_icon;
      css = "* { color: red; }"
    }
  }
}

#Api2

Module("idleinhibit");

Private {
  Var icon_active = "icons/misc/lock-symbolic";
  Var icon_inactive = "icons/misc/unlock-symbolic";

  export button {
    value = If(IdleInhibitState()="on", icon_active, icon_inactive);
    style = If(Ident(IdleInhibitState), "idleinhibit", "hidden");
    class = "module";
    tooltip = "Idle inhibitor: " + IdleInhibitState();
    local = true;
    trigger = "idleinhibitor";
    action[1] = SetIdleInhibitor("toggle");
  }
}
